{
  "name": "@bilalpm/musicli",
  "version": "0.1.4",
  "description": "A simple music player in your terminal",
  "type": "module",
  "bin": {
    "musicli": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "test": "npm run build && node --import tsx --test test/**/*.test.ts",
    "postinstall": "node scripts/patch-speaker-coreaudio.mjs",
    "prepack": "npm test",
    "tracks:normalize": "node scripts/normalize-track-filenames.mjs",
    "tracks:retitle": "node scripts/retitle-track-pairs.mjs",
    "tracks:build": "node scripts/build-track-library.mjs && node scripts/build-library-manifests.mjs",
    "library:build": "node scripts/build-library-manifests.mjs",
    "library:stage": "node scripts/stage-library-source.mjs"
  },
  "files": [
    "assets",
    "dist",
    "scripts/patch-speaker-coreaudio.mjs",
    "sounds"
  ],
  "keywords": [
    "lofi",
    "cli",
    "terminal",
    "music",
    "ambient",
    "focus"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/btahir/musicli.git"
  },
  "homepage": "https://github.com/btahir/musicli#readme",
  "bugs": {
    "url": "https://github.com/btahir/musicli/issues"
  },
  "license": "MIT",
  "dependencies": {
    "commander": "^13.1.0",
    "figlet": "^1.8.0",
    "gradient-string": "^3.0.0",
    "pngjs": "^7.0.0",
    "speaker": "^0.5.4"
  },
  "devDependencies": {
    "@types/figlet": "^1.7.0",
    "@types/node": "^22.13.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
